// ────────────────────────────────────────────────────────────────────
// URFS Web — full-port spec
//
// Source of truth for the webapp's "no gaps" build-out. Each iteration
// of /loop /urfs-webapp-iterate picks the next pending item, ships it,
// bumps the version, updates the README changelog, commits.
//
// Status values: pending | in_progress | done | blocked
// Version scheme: 0.0.N pre-release. Each item shipped bumps N.
//
// Rules: webapp is single-file (index.html). All code goes there.
// IndexedDB shape MUST stay compatible with the Android RobotEntity /
// ComponentEntity / ModuleInstance / BattleState so a future Android
// importer can read the JSON export round-trip.
// ────────────────────────────────────────────────────────────────────
{
  meta: {
    repo: "/home/tom/software_projects/urfs/webapp",
    file: "index.html",
    branch: "master",
    current_version: "0.0.40",
    rulebook: "/home/tom/software_projects/urfs/android/app/src/main/assets/rulebook.md",
    revision_notes: "/home/tom/software_projects/urfs/docs/rulebook/RULEBOOK_REVISION_NOTES.md",
    android_reference: "/home/tom/software_projects/urfs/android/app/src/main",
    constraint_single_file: true,
    note: "Android side already implements everything here. Port the algorithm, don't redesign.",
  },

  // ── Stage 1: bind pilots to cockpit slots at deploy ────────────────
  // Unblocks the dice-roller pilot-talent chips (Sharpshooter, Deadeye,
  // Brawler) AND the action-resolve strain routing.
  stage_1_cockpit_binding: [
    {
      id: "cockpit.collect_slots_from_robot",
      summary: "Derive cockpit slot count per robot from its components (any module whose catalog entry marks it as a cockpit-bearing module — single-pilot, multi-pilot, open-air, etc). Adapter only — no UI.",
      depends_on: [],
      status: "done",
      acceptance: "robotCockpitSlots(r) returns array of {componentId, componentName, moduleIndex, moduleId, slotIndex, slotName} for every cockpit slot the robot exposes. Multi-pilot modules contribute multiple slots.",
      history: [
        { when: "2026-06-05", who: "claude", note: "picked up — implementing adapter only, no UI surface." },
        { when: "2026-06-05", who: "claude", note: "shipped in 0.0.3. robotCockpitSlots() at index.html:726-756. Returns {componentId, componentName, moduleIndex, moduleId, moduleName, slotIndex, slotName, isAi} per slot. componentId fallback handles build (tempId) vs battle/force (componentId). Multi-pilot supported via inner capacity loop. 6 Playwright eval cases verified: empty, single, dual (Std+AI), unknown-module skip, non-cockpit-module skip, input-unmutated." },
      ],
    },
    {
      id: "cockpit.deploy_step_assign_pilots",
      summary: "Force deploy flow: after picking robots, show a pilot-assignment step. One picker per cockpit slot. Validates: no double-booking pilots across slots.",
      depends_on: ["cockpit.collect_slots_from_robot"],
      status: "done",
      acceptance: "Deploying a force with N cockpit-bearing mechs prompts N×slots pilot pickers; cancel returns to robot picker; confirm stores assignments on battle.cockpitPilots[].",
      history: [
        { when: "2026-06-05", who: "claude", note: "picked up — inserting pilot-assignment step between deploy click and battle launch." },
        { when: "2026-06-05", who: "claude", note: "shipped in 0.0.4. forceCockpitSlots(force) adapter (pure) + renderPilotAssign modal with per-slot <select> + double-booking filter + AI-Core auto-skip + 0-cockpit fast-path + empty-pilots empty-state banner with GO TO PILOTS shortcut. Wired through document-level change delegation (matches data-act convention). deployForceWithAssignments builds battle.cockpitPilots[] = [{componentId, moduleIndex, slotIndex, slotName, pilotId, isAi, sysStrain:0, pilotStrain:0}] per slot. 7+3 Playwright cases verified." },
      ],
    },
    {
      id: "cockpit.persist_in_battle_state",
      summary: "battle.cockpitPilots = [{robotId, componentId, slotIndex, pilotId, sysStrain:0, pilotStrain:0}]. Survives IndexedDB round-trip.",
      depends_on: ["cockpit.deploy_step_assign_pilots"],
      status: "done",
      acceptance: "Export JSON includes cockpitPilots[]; import restores them; per-robot screen reads them.",
      history: [
        { when: "2026-06-05", who: "claude", note: "picked up. DECISION_LOG: previous slice stored cockpitPilots nested on each BattleRobotState (per-robot) rather than flat at battle level. Keeping that shape — destruction cascades + display affordances are O(1) when nested. Spec text 'battle.cockpitPilots' read as 'somewhere on the battle object' rather than literal top-level key." },
        { when: "2026-06-05", who: "claude", note: "shipped in 0.0.5. Round-trip verified — generic export/import pipeline carries cockpitPilots through the battles store without code changes. renderCockpitPilots(r) added between vitals and action sheet on per-robot screen: cyan-accented PILOTS bucket with one row per cockpit (slot name + pilot name chip + rank · STR sysStrain/pilotStrain; AI Core slots show 'A.I. Core' chip; stale-id pilots show 'unassigned'). New CSS: .bucket.pilots .header (cyan), .bucket.pilots.open border-color, .header.static / .list-card.static cursor:default to remove false-affordance from non-clickable rows. 3 Playwright cases verified including round-trip + visual." },
      ],
    },
    {
      id: "cockpit.pilot_picker_in_action_resolve",
      summary: "When an action needs strain routing (most Primary actions), ActionResolveDialog shows a pilot picker listing every cockpit pilot on this robot.",
      depends_on: ["cockpit.persist_in_battle_state"],
      status: "done",
      acceptance: "Salvo + Charge + Melee Assault + Heat Vent show pilot picker; RESOLVE routes the +1 P STRAIN to that pilot's pilotStrain.",
      history: [
        { when: "2026-06-05", who: "claude", note: "picked up. Plan: add pilot picker to ActionResolveDialog when action.pilotStrainCost > 0; on RESOLVE, mutate the chosen cockpitPilots entry's pilotStrain." },
        { when: "2026-06-05", who: "claude", note: "shipped in 0.0.6. New helpers actionShowsPilotPicker(k) {SALVO|CHARGE|MELEE_ASSAULT|HEAT_VENT} and actionPilotStrainCost(k) (1 for first three, 0 for HEAT_VENT — Mental check is Free). Picker rewritten to filter humanCockpits (skip AI), composite-key 'componentId:moduleIndex:slotIndex' identity (not array index), default-pick first human row with cyan-border highlight, MANUAL escape-hatch preserved. RESOLVE handler replaces stale .tokens reference with cockpitPilots.find().pilotStrain += cost; sysStrain unchanged (still bumps for primary/reaction bucket). PASS handler bug fixed: now clears pilotStrain on every cockpit pilot (per v0.0.1 README + rulebook, PASS clears Pilot Strain). DECISION_LOG: auto-default pick on first render is intentional UX (single-cockpit case saves a tap; multi-cockpit user sees cyan border on default + can tap to override). modal-close resets _pickedPilot to null to prevent cross-action leak. 7+1 Playwright cases verified including PASS→strain=0 round-trip." },
      ],
    },
    {
      id: "cockpit.dice_chips_wake_up",
      summary: "Dice roller chip catalog: enumerate the cockpit pilots on this robot and surface their talent chips (Sharpshooter for ranged, Deadeye for ranged, Brawler for melee, etc.).",
      depends_on: ["cockpit.persist_in_battle_state"],
      status: "done",
      acceptance: "Open dice roller for SALVO with a Sharpshooter pilot bound → Sharpshooter chip appears, togglable, +1 die when active.",
      history: [
        { when: "2026-06-05", who: "claude", note: "picked up. Plan: walk cockpitPilots → lookup pilot.talents → emit matching chips for the rollKind." },
        { when: "2026-06-05", who: "claude", note: "shipped in 0.0.7. Fixed dormant bug in rollerComputeChips: was reading cp.talents off the cockpitPilots entry shape (which never had a talents field) — now looks up talents via state.pilots.find(p => p.id === cp.pilotId)?.talents, filtered to non-AI cockpits with a pilotId. Sharpshooter/Deadeye/Brawler chip enumeration was already correct, just sourced empty. Acceptance verified: deploy Eagle (Sharpshooter+Brawler) → SALVO roller surfaces +3 SHARPSHOOTER chip; CHARGE surfaces +1 BRAWLER; MENTAL surfaces neither. Toggle+pool: base 4 + Sharpshooter 3 = 7 d6 displayed." },
      ],
    },
  ],

  // ── Stage 2: two-sided combat (P2 force + priority handoff) ────────
  stage_2_two_sides: [
    {
      id: "twosides.battle_state_two_forces",
      summary: "battle.forces = [{side:'P1', forceId, robotIds[]}, {side:'P2', forceId, robotIds[]}]. Migration: existing single-force battles become side='P1', P2 empty.",
      depends_on: [],
      status: "done",
      acceptance: "Old export JSON imports fine; new battles store both sides; per-robot screens still resolve correctly.",
      history: [
        { when: "2026-06-05", who: "claude", note: "picked up. DECISION_LOG: existing webapp model already has battle.p1Robots[] + battle.p2Robots[] (p2 always [] for now) and battle.p1ForceName + battle.p2ForceName. Keeping this shape — it's structurally equivalent to the spec's battle.forces[] proposal. This iteration: add findBattleRobot(b, rid) lookup helper that searches both sides, ensure legacy battles get p2Robots:[] default on import, add p1ForceId for traceability." },
        { when: "2026-06-05", who: "claude", note: "shipped in 0.0.8. findBattleRobot(b, rid) helper added; 31 prior p1Robots.find() callsites refactored to use it (searches both p1 + p2). p1ForceId stored on deploy (next slice will read it for OPPONENT styling). renderBattleOverview now renders OPPONENT FORCE section when p2Robots.length > 0; solo battles unchanged. Legacy migration applied at BOTH ingress paths: init (load from IndexedDB) AND import-json — old battles missing p2Robots default to []. Playwright regression check: p1 lookup, p2 lookup, SALVO → pilotStrain++, p1ForceId set. Forward-prep: p1ForceId/p2ForceId are write-only until next slice; OPPONENT section uses neutral chrome (will get --red palette in twosides.battle_overview_both_sides)." },
      ],
    },
    {
      id: "twosides.deploy_picks_two_forces",
      summary: "Deploy flow asks: P1 force + P2 force (optional). If P2 omitted, default-empty (skirmish/solo).",
      depends_on: ["twosides.battle_state_two_forces"],
      status: "done",
      acceptance: "Deploy 2 forces → battle has 6 robot cards in two sections (YOUR / OPPONENT).",
      history: [
        { when: "2026-06-05", who: "claude", note: "picked up. DECISION_LOG: post-deploy '+ ADD OPPONENT FORCE' button on battle overview rather than re-plumbing pre-deploy flow. Less disruption to v0.0.4 pilot-assign code; mirrors table-play where opponent may show up later. Tap opens force picker (excluding current p1ForceId) → existing pilot-assign modal reused with side='P2' context → robots pushed to p2Robots, p2ForceId set." },
        { when: "2026-06-05", who: "claude", note: "shipped in 0.0.9. New '+ ADD OPPONENT FORCE' button on battle overview (visible when p2Robots.length === 0). renderOpponentForcePicker filters out (a) the deployed P1 force AND (b) any force that contains a robot.id also in p1Robots — second filter prevents findBattleRobot collisions (first-match-wins would make a P2 instance unreachable). Reused renderPilotAssign with side='P2' param; confirm-pilot-assign branches: P1 → deployForceWithAssignments creates new battle (unchanged), P2 → builds battle-robot states for the existing battle and pushes to p2Robots. p1ForceName has 'your force' fallback for legacy battles. 7+1 Playwright cases verified: end-to-end 1+2 deploy, collision filter excludes Force C (shares robot with deployed P1), legacy-battle fallback label." },
      ],
    },
    {
      id: "twosides.battle_overview_both_sides",
      status: "done",
      summary: "Battle overview renders YOUR FORCE and OPPONENT FORCE sections, each with their robot cards. Tap-to-detail works on either side.",
      history: [
        { when: "2026-06-05", who: "claude", note: "shipped in 0.0.10. CSS: new .card.friendly (3px cyan left border) and .card.opposing (3px red left border) modifiers; reused existing --cyan / --red tokens. renderBattleOverview headers use .label-cyan / .label-red on YOUR / OPPONENT label-small. robotOverviewCard now applies sideClass = r.side === 'P2' ? 'opposing' : 'friendly'. Tap-to-detail verified for P2 (clicked P2Bot card → state.activeRobotId === 4002 via findBattleRobot). Visual screenshot captured." },
      ],
      depends_on: ["twosides.deploy_picks_two_forces"],
      acceptance: "Visual: two header sections with color-distinct chrome (cyan vs red).",
    },
    {
      id: "twosides.priority_handoff",
      summary: "Round tracker shows current priority holder (P1 or P2). PASS PRIORITY button hands off to the other side. After both have passed, end of round.",
      depends_on: ["twosides.battle_overview_both_sides"],
      status: "done",
      history: [
        { when: "2026-06-05", who: "claude", note: "picked up. Plan: add b.passedThisRound={P1:false,P2:false}; PASS marks current priority side passed + flips; on double-pass advance round + reset flags + reset priority to P1; existing handler is buggy (only resets P1, uses stale .tokens field)." },
        { when: "2026-06-05", who: "claude", note: "shipped in 0.0.11. pass-priority handler rewritten as a proper state machine. Reads current b.priority, clears pilot strain on THAT side only (was the bug — old code only ever cleared P1), marks b.passedThisRound[side]=true, flips priority to other side. When both sides have b.passedThisRound true, advances round: round++, passedThisRound reset, priority reset to P1. Solo (p2Robots empty) takes a fast path — single PASS advances the round directly. UI: per-side chip shows '✓ PASSED' (muted) when that side has passed, 'PRIORITY' (amber) when that side holds priority. 3-state trace verified: Round 1 P1→P2 priority with P1 strain cleared; P2 pass → Round 2 begins with both strains cleared; solo path → single PASS → Round 2." },
      ],
      acceptance: "Round 1 → P1 has priority → P1 PASS → P2 has priority → P2 PASS → Round 2 begins.",
    },
  ],

  // ── Stage 3: action budget + round state machine ──────────────────
  stage_3_action_budget: [
    {
      id: "budget.per_robot_action_pool",
      summary: "Per-robot per-round: 1 Primary, 2 Reactions, ∞ Incidentals. State held on battle.robotState[robotId] = {primaryUsed, reactionsUsed, incidentalsUsed}.",
      depends_on: ["twosides.priority_handoff"],
      status: "done",
      acceptance: "Spending an action increments the right counter; state persists on save/restore.",
      history: [
        { when: "2026-06-05", who: "claude", note: "picked up. DECISION_LOG: storing actionBudget nested on each BattleRobotState (consistent with cockpitPilots[] pattern) instead of a sibling battle.robotState{robotId} map. Easier round-trip, easier per-robot lookup, no map serialization concerns. Spec's literal map form is functionally equivalent." },
        { when: "2026-06-05", who: "claude", note: "shipped in 0.0.12. buildBattleRobotState now initializes actionBudget:{primaryUsed:0, reactionsUsed:0, incidentalsUsed:0}. resolve-action handler bumps the matching counter (primary/reaction/incidental from a.bucket) on each resolve (excluding PASS, which is its own thing). pass-priority's round-advance branch resets all robots' actionBudget back to zeros across both sides. 5-phase Playwright trace verified: deploy 0/0/0 → Salvo 1/0/0 → Dodge 1/1/0 → Pivot 1/1/1 → PASS round-up 0/0/0 + round=2. UI affordances (disable spent buttons, ACTIONS THIS ROUND chip) come in the next two slices." },
      ],
    },
    {
      id: "budget.disable_spent_actions",
      summary: "ActionResolveDialog: if a Primary was already used this round, all Primary actions render dimmed + disabled. Same for 2 Reactions used.",
      depends_on: ["budget.per_robot_action_pool"],
      status: "done",
      acceptance: "After Salvo resolves, every Primary action in the list is unselectable until end of round.",
      history: [
        { when: "2026-06-05", who: "claude", note: "picked up. Plan: dim+disable in renderActionSheet via .action-btn[disabled] (existing CSS) when bucket over cap. PASS is the exception — always available regardless of primary budget. Defense-in-depth: guard open-action handler too." },
        { when: "2026-06-05", who: "claude", note: "shipped in 0.0.13. renderActionSheet now reads r.actionBudget and emits `disabled` attribute + 'PRIMARY SPENT' or 'REACTION SPENT' reason chip (.reason orange) on cards over cap. PASS is exempt (it ends the round even after primary is spent). open-action handler also guards programmatically with a showToast on attempted bypass. Existing .action-btn:disabled { opacity: 0.4 } CSS handles the visual. 4-phase trace + visual screenshot verified." },
      ],
    },
    {
      id: "budget.actions_this_round_panel",
      summary: "Per-robot screen: ACTIONS THIS ROUND chip row: P:1/1, R:0/2, I:3. Color when at-cap.",
      depends_on: ["budget.per_robot_action_pool"],
      status: "done",
      acceptance: "Visual chips that mirror rulebook caps.",
      history: [
        { when: "2026-06-05", who: "claude", note: "picked up. Adding renderActionBudget(r) between PILOTS section and action sheet. Chip row: ACTIONS THIS ROUND · P:n/1 · R:n/2 · I:n. Amber chip when at cap." },
        { when: "2026-06-05", who: "claude", note: "shipped in 0.0.14. renderActionBudget(r) renders a thin .card.tight row with the label and 3 chips (P:n/1, R:n/2, I:n). Amber chip class applied when the bucket is at cap; default cyan chip otherwise. Inserted between renderCockpitPilots and renderActionSheet. Trace verified: deploy 0/0/0 → after Salvo+Dodge: 1/1/0, P chip is amber." },
      ],
    },
    {
      id: "budget.end_of_round_refresh",
      summary: "End-of-round button: refresh all robots' budgets, increment round counter, tick strain recovery if rules allow, fire +1 capacitor.",
      depends_on: ["budget.actions_this_round_panel"],
      status: "done",
      acceptance: "Round 2 begins → every robot back to P:0/1, R:0/2, I:0; +1 capacitor on robots that don't override.",
      history: [
        { when: "2026-06-05", who: "claude", note: "picked up. DECISION_LOG: existing PASS PRIORITY already handles round advance (v0.0.11), and the manual + ROUND button at overview is the explicit 'end-of-round' affordance — no need for a 3rd button. Tasks: (1) introduce r.capacitorsMax at deploy via calcCapacitorPool, (2) apply +1 capacitor (clamped to max) on both round-advance paths, (3) strain recovery — rulebook has no auto-strain-tick per round (cleared by Strain Clear incidental), so skipping that spec mention." },
        { when: "2026-06-05", who: "claude", note: "shipped in 0.0.15. buildBattleRobotState now stores capacitorsMax (mirror of starting capacitorsRemaining). Both round-advance paths (pass-priority's double-pass branch AND the manual + ROUND button) now apply r.capacitorsRemaining = Math.min(capacitorsMax, capacitorsRemaining + 1) for every robot on both sides. round-next handler was also missing the budget/passedThisRound/priority resets — those are now wired so manual + ROUND mirrors the natural PASS round-advance. Trace verified: 2 capacitor_bank modules → max=4 starting=4, spend→3, PASS → round 2 cap=4 (clamped, not 5), + ROUND → round 3 cap=4 (stays clamped). Stage-3 action-budget chain closes." },
      ],
    },
  ],

  // ── Stage 4: damage pipeline (buffer → frame save → cascade) ──────
  // This is the marathon. Port from android SchematicBattleViewModel +
  // FrameSaveResolver + DestructionCascade.
  stage_4_damage_pipeline: [
    {
      id: "damage.apply_damage_dialog",
      summary: "New APPLY DAMAGE button on per-robot screen. Target component picker + damage-amount input + type (kinetic/energy/etc).",
      depends_on: [],
      status: "done",
      acceptance: "Opens a dialog; on submit, calls applyDamage(robotId, componentId, amount, type).",
      history: [
        { when: "2026-06-05", who: "claude", note: "picked up. UI surface only — applyDamage is a stub here; pipeline (buffer → frame save → cascade) ships in the subsequent slices." },
        { when: "2026-06-05", who: "claude", note: "shipped in 0.0.16. APPLY DAMAGE button added to schematic toolbar (next to RESET ARMOR). renderApplyDamage modal: component <select> showing alive components + 'armor n/m' preview, AMOUNT number input, PHYSICAL/ENERGY toggle buttons (PHYSICAL default). APPLY disabled at amount 0. apply-damage-submit calls applyDamage(robotId, componentId, amount, type) — stub records {when, componentId, amount, type} on r.damageLog, toasts. Pipeline (buffer absorbs, frame save, destruction cascade) ships in damage.buffer_absorbs_first → damage.recompute_derived_stats." },
      ],
    },
    {
      id: "damage.buffer_absorbs_first",
      summary: "applyDamage: subtract from component.armor first (down to 0). Overflow = breach. No frame save if armor absorbed everything.",
      depends_on: ["damage.apply_damage_dialog"],
      status: "done",
      acceptance: "Component with armor 5, take 3 damage → armor=2, no save prompt. Take 7 damage → armor=0, save prompted on 2 breach.",
      history: [
        { when: "2026-06-05", who: "claude", note: "picked up. DECISION_LOG: webapp battle-component shape stores armor as hpCurrent/hpMax (legacy v0.0.1 naming — kept because RESET ARMOR already operates on those fields). Treating c.hpCurrent as the current armor/buffer in this slice. The next slice (frame save) actually triggers the save dialog; this one just absorbs and identifies the breach amount." },
        { when: "2026-06-05", who: "claude", note: "shipped in 0.0.17. applyDamage now computes absorbed=min(armor, amount) and breach=amount-absorbed; mutates c.hpCurrent down to 0; pushes {absorbed, breach} on r.damageLog; toast describes outcome. Returns {absorbed, breach} for the frame-save caller in next slice. 3 cases verified: armor 5/take 3 → armor 2 breach 0; armor 5/take 7 → armor 0 breach 2; armor 0/take 4 → armor 0 breach 4." },
      ],
    },
    {
      id: "damage.frame_save_dialog",
      summary: "On breach: dialog showing FD d6 vs 7-FM+ threshold. Roll button. Outcome is binary: save success → component intact; save fail → component destroyed (no HP loss — components have no HP stat per rulebook).",
      depends_on: ["damage.buffer_absorbs_first"],
      status: "done",
      acceptance: "FD=2, FM=3 → roll 2 d6 vs 4+. Show dice, count hits. Hits ≥ 1 = save succeeds, breach absorbed. Hits = 0 = component is destroyed (binary).",
      history: [
        { when: "2026-06-05", who: "claude", note: "picked up. applyDamage opens frame-save modal on breach > 0; modal renders FD d6 vs 7-FM+ threshold + ROLL button. Roll → mark dice that meet threshold as hits → hits ≥ 1: save passes (component intact); hits = 0: c.isDestroyed = true. Cascade fires in next slice." },
        { when: "2026-06-05", who: "claude", note: "shipped in 0.0.18. applyDamage pushes frame-save modal when breach > 0. renderFrameSave shows '<comp> took N breach. Roll FD d6 vs (7-FM)+.' + amber-hit / muted-miss per-die chips on roll + ✓ SAVED · N hits in cyan or ✗ DESTROYED · 0 hits in red. SKIP (manual) button preserves at-table resolution path. frame-save-roll handler rolls dice, applies binary outcome: hits=0 → c.isDestroyed=true, c.hpCurrent=0. Cascade fires next slice. PREREQ FIX: buildBattleRobotState now carries frameStrength/frameDurability/frameMaterial onto BattleRobotState (was missing — caused FD/FM to default to 1). 2 cases verified at FD=2/FM=3 (threshold 4+): [5,5]→2 hits→intact; [1,1]→0 hits→destroyed." },
      ],
    },
    {
      id: "damage.destruction_cascade",
      summary: "Failed save → component.isDestroyed = true → cascade per Android: stowed children destroyed, fuel-tank components spill (collateral), equipment-grabber components drop equipment.",
      depends_on: ["damage.frame_save_dialog"],
      status: "done",
      acceptance: "Failed save destroys component; destroy a host with 3 stowed components → all 3 marked destroyed; destroy a fuel tank → adjacent components take spill damage per rulebook.",
      history: [
        { when: "2026-06-05", who: "claude", note: "picked up. Cascade order: (1) recursively destroy children where parentTempId === this.componentId (handles arbitrary depth), (2) if this had a fuelCapacity > 0 module, apply silhouette damage to siblings + parent direct-to-buffer (no nested frame save), (3) drop all equipment[]." },
        { when: "2026-06-05", who: "claude", note: "shipped in 0.0.19. destroyComponent(robotId, componentId): marks isDestroyed+hpCurrent=0, recursively cascades children via parentComponentId (NEW field on battle component — buildBattleRobotState was missing it), then if hadFuel applies silhouette spillage damage directly to buffer of siblings+parent (no nested Frame Save modal), then drops equipment[] into r.droppedEquipment[]. Spillage breaches go to log; manual APPLY DAMAGE re-roll lets player resolve those if desired. frame-save-roll now calls destroyComponent on 0-hits outcome. cascadeLog tracks every event. 2 cases verified: (A) destroy mid-spine Arm → Hand cascades, equipment 'Sword' lands in droppedEquipment, sibling untouched. (B) destroy fuel-carrying Core → Arm+Hand cascade 3-deep, sibling takes silhouette 3 spillage damage absorbed by armor 5 → 2." },
      ],
    },
    {
      id: "damage.recompute_derived_stats",
      summary: "After any destruction: recomputeShieldsMax, recomputeCapacitorPool, enforceAuxReactorDependency, refreshPowerAndCheck, recomputeStrainThreshold. Port from Android.",
      depends_on: ["damage.destruction_cascade"],
      status: "done",
      acceptance: "Destroying the shields module zeros the SHLD max; destroying aux reactor disables dependent modules.",
      history: [
        { when: "2026-06-05", who: "claude", note: "picked up. Wrap existing calcShieldsMax / calcCapacitorPool / calcStrainThreshold with a filter that excludes destroyed components (those modules no longer contribute). Wire from destroyComponent tail; clamp current values down to new max." },
        { when: "2026-06-06", who: "claude", note: "shipped in 0.0.20. recomputeDerivedStats(r) wraps existing build-shape calcs (calcShieldsMax / calcCapacitorPool / calcStrainThreshold) with a shadow robot whose components are filtered to !isDestroyed — modules on destroyed components no longer contribute. Clamps shieldsCurrent/capacitorsRemaining to the new max. Also walks alive modules and disables (toggledOn=false) any whose `requires` chain no longer points to a live module (handles aux reactor → dependent modules). Wired from destroyComponent tail. 2 cases verified: (A) destroy a UTILITY hosting shield_gen + capacitor_bank → shieldsMax 3→0 with current clamped, capacitorsMax 2→0 with current clamped, strain unchanged. (B) destroy a Core hosting 'armor' → armor_coating's requires:['armor',...] no longer satisfied → coating.toggledOn flipped from true to false." },
      ],
    },
    {
      id: "damage.undo_restore_in_combat",
      summary: "Port restoreComponent from Android alpha.356: UNDO·RESTORE button on destroyed-component overlay clears flag, restores HP, re-runs recompute helpers.",
      depends_on: ["damage.recompute_derived_stats"],
      status: "done",
      acceptance: "Misclick destroy → tap UNDO·RESTORE → component back to full HP, derived stats snap back.",
      history: [
        { when: "2026-06-06", who: "claude", note: "picked up. UI surface exists since v0.0.2 (UNDO·RESTORE button rendered when isDestroyed). Handler exists but doesn't call recomputeDerivedStats — adding that call so shields/cap/strain snap back like the Android alpha.356 restore." },
        { when: "2026-06-06", who: "claude", note: "shipped in 0.0.21. restore-comp handler now calls recomputeDerivedStats(r) after clearing isDestroyed + restoring hpCurrent. Per alpha.356: cascade collateral (stowed children, fuel-spilled siblings, dropped equipment) is NOT auto-rewound — player taps each one individually. Verified destroy→restore round-trip on shield_gen-bearing Core: shieldsMax 3→0→3 (recompute), hpCurrent 4→0→4 (refill), isDestroyed flag false→true→false. Closes stage 4 damage pipeline." },
      ],
    },
  ],

  // ── Stage 5: strain effects (Shutdown reboot, Pilot KO, etc.) ─────
  stage_5_strain_effects: [
    {
      id: "strain.shutdown_threshold_check",
      summary: "When sysStrain reaches strainThreshold (default 6), prompt Shutdown reboot test on this robot's next action attempt.",
      depends_on: [],
      status: "done",
      acceptance: "Bump sysStrain to 6 → next action click shows Shutdown overlay before resolving.",
      history: [
        { when: "2026-06-06", who: "claude", note: "picked up. Plan: after every strain bump (resolve-action's primary/reaction branch), if sysStrain >= threshold set r.shutdownPending=true. open-action handler intercepts when shutdownPending → opens shutdown-reboot modal (stub here, real roll dialog in next slice). STRAIN_CLEAR + HEAT_VENT remain available — those drain strain so they're the way OUT of the gate." },
        { when: "2026-06-06", who: "claude", note: "shipped in 0.0.22. resolve-action primary/reaction branch + bump-strain handler now set r.shutdownPending = true when sysStrain >= threshold, and the bump-strain handler clears it when strain drops back below threshold. open-action handler intercepts when shutdownPending=true and routes to the new shutdown-reboot modal — EXCEPT for STRAIN_CLEAR / HEAT_VENT (escape hatches) and PASS (priority pass). r.shutdown=true (post-fail) makes the handler refuse all non-PASS actions. renderShutdownReboot is a placeholder (banner + DISMISS button); the actual FD d6 vs 5+ reboot roll lands in strain.shutdown_reboot_test. 6-step trace verified." },
      ],
    },
    {
      id: "strain.shutdown_reboot_test",
      summary: "Shutdown overlay: roll FD d6 vs 5+ to reboot. Fail → Shutdown stays until next round (skip turn).",
      depends_on: ["strain.shutdown_threshold_check"],
      status: "done",
      acceptance: "Roll dialog with FD dice; success = sysStrain -= 3 and Shutdown cleared; fail = robot.shutdown=true.",
      history: [
        { when: "2026-06-06", who: "claude", note: "picked up. Replace v0.0.22 placeholder with real roll dialog mirroring Frame Save shape: FD d6 vs 5+, success → sysStrain-=3 + shutdownPending=false, fail → r.shutdown=true. Round-advance (pass-priority + round-next) also resets r.shutdown so Shutdown robot can act next round." },
        { when: "2026-06-06", who: "claude", note: "shipped in 0.0.23. renderShutdownReboot replaced placeholder with real dice UI: amber-hit / muted-miss chips per die, ✓ REBOOTED · N hits · −3 Strain or ✗ SHUTDOWN · 0 hits banner. shutdown-reboot-roll handler: FD d6 vs 5+, success → r.systemStrain = max(0, prev-3) + clear shutdownPending, fail → r.shutdown=true + clear pending. round-advance (both pass-priority double-pass branch AND round-next manual) now resets r.shutdown=false. 3 cases verified: [5,5]→2 hits→strain 5→2, shutdownPending false; [1,1]→0 hits→strain unchanged, shutdown true; round-next → shutdown false again." },
      ],
    },
    {
      id: "strain.pilot_knockout_threshold",
      summary: "Per-pilot Pilot Strain threshold (5 + training). At threshold: KO. KO removes pilot from cockpit until first aid.",
      depends_on: [],
      status: "done",
      acceptance: "Pilot at 5 strain with training 0 → KO overlay; remove from cockpit slot.",
      history: [
        { when: "2026-06-06", who: "claude", note: "picked up. cp.isKO=true when cp.pilotStrain >= 5 + pilot.training; PILOTS section shows KO chip + dim; pilot picker filters KO pilots out (treated as absent for strain routing)." },
        { when: "2026-06-06", who: "claude", note: "shipped in 0.0.24. resolve-action strain-routing branch now computes koThreshold = 5 + pilot.training after the pilotStrain bump; if cp.pilotStrain >= threshold and not already KO'd, flips cp.isKO=true and toasts 'Name KO'd! (M/N P-Strain)'. PILOTS section row dims at opacity 0.5 + adds a red KO chip; P-STR display now shows current/threshold (e.g. '5/5') instead of sys/pilot. ActionResolveDialog pilot picker filters humanCockpits with `!c.isAi && !c.isKO` so KO'd slots are treated as absent for strain routing. Verified rookie pilot (training 0) bumped from pilotStrain 4 to 5 via SALVO → isKO=true, KO chip visible, row dimmed, picker shows 0 humans." },
      ],
    },
    {
      id: "strain.strain_clear_action",
      summary: "Verify Strain Clear incidental: spend 1 capacitor, reduce 1 system strain. Already wired? Port if not.",
      depends_on: [],
      status: "done",
      acceptance: "Resolving Strain Clear with cap≥1: cap -= 1, sysStrain -= 1.",
      history: [
        { when: "2026-06-06", who: "claude", note: "STRAIN_CLEAR core mechanic already wired since v0.0.6: resolve-action checks cap > 0 AND sysStrain > 0, decrements both, toasts. ONLY gap: doesn't clear r.shutdownPending if strain drops below threshold after the clear. Adding that tail." },
        { when: "2026-06-06", who: "claude", note: "shipped in 0.0.25. STRAIN_CLEAR branch now also clears r.shutdownPending when systemStrain drops below threshold post-decrement. Verified: cap2/strain3/thresh2 → clear once → cap1/strain2/pending stays (still ≥ thresh); clear twice → cap0/strain1/pending false; cap0 → no-op. Stage 5 has Heat Vent left, then stage 5 closes." },
      ],
    },
    {
      id: "strain.heat_vent_reaction",
      summary: "Heat Vent: spend a Reaction, roll Mental check, on success remove 2 sysStrain. Wires through ActionResolveDialog.",
      depends_on: [],
      status: "done",
      acceptance: "Heat Vent → pilot picker → roll Mental → on hit, sysStrain -= 2 and reaction budget incremented.",
      history: [
        { when: "2026-06-06", who: "claude", note: "picked up. DECISION_LOG: rulebook L266 says 'Remove System Strain equal to hits', NOT a flat -2. Following rulebook over spec's '-2'. Bucket stays incidental per the catalog (rulebook says 'Can be a Reaction' — situational reaction-use ships when reaction-specific triggers exist). Mental check: roll pilot.mental d6 vs 5+ on RESOLVE." },
        { when: "2026-06-06", who: "claude", note: "shipped in 0.0.26. New HEAT_VENT branch in resolve-action: reads picked pilot's mental stat from state.pilots, rolls that many d6 via Math.random, counts hits ≥ 5. On hits ≥ 1: r.systemStrain -= hits (clamped to 0) + clears shutdownPending if it drops below threshold. Toast describes outcome (dice + hits + strain delta) with pilot name. MANUAL bypasses auto-roll. No-rolling-pilot fallback toasts to resolve at table. Bucket stays incidental → incidental budget increments per existing logic. 3 cases verified: [5,6,5]→3 hits→strain 5→2, pending cleared; [1,1,1]→0 hits→no change; MANUAL→no auto-roll. Closes stage 5 strain effects." },
      ],
    },
  ],

  // ── Stage 6: action-specific dice flows ───────────────────────────
  stage_6_action_dice_flows: [
    {
      id: "dice.salvo_per_target_plus_mental",
      summary: "Salvo: per-target ranged attack roll. If targets > Mental, an extra Mental check. Each target receives one token.",
      depends_on: ["cockpit.dice_chips_wake_up"],
      status: "done",
      acceptance: "Pick 3 targets with Mental 2 → 3 ranged rolls + 1 Mental check; tokens land on each target.",
      history: [
        { when: "2026-06-06", who: "claude", note: "picked up. Add multi-target picker to SALVO action-resolve dialog (lists other battle robots, checkboxes). On RESOLVE: bump r.salvoTokens per target by 1; if targetCount > pilot.Mental, toast 'Mental check required'. Per-target ranged rolls happen via existing dice roller (open separately). Sysstrain + pilotStrain bumps unchanged (existing v0.0.6 logic)." },
        { when: "2026-06-06", who: "claude", note: "shipped in 0.0.27. ActionResolveDialog gains a TARGETS section when k===SALVO: lists every battle robot except self (P1+P2, skipping destroyed), each card tappable to toggle inclusion. open-action initializes state.modal.data.targetIds=[]; toggle-salvo-target handler mutates that list and re-renders. Header shows count + Mental check warning when count > pilot.mental. RESOLVE applies +1 salvoTokens to each picked target's battle state and toasts if Mental check needed. Spec acceptance verified: pilot Mental 2, 3 P2 targets selected → all 3 receive salvoTokens=1, sysStrain bumps, primary budget consumed." },
      ],
    },
    {
      id: "dice.charge_move_plus_melee",
      summary: "Charge: ½ GSPD move + melee attack roll. Resolve dice as melee attack.",
      depends_on: [],
      status: "done",
      acceptance: "Charge → distance picker → ½ GSPD spent → melee roll dice.",
      history: [
        { when: "2026-06-06", who: "claude", note: "picked up. ActionResolveDialog for CHARGE shows distance picker (0..floor(groundSpeed/2)). On RESOLVE: r.gspdSpent += distance; round advance resets gspdSpent (in pass-priority + round-next per existing budget reset). Existing OPEN DICE ROLLER button already routes to MELEE roll context. Per-robot screen GSPD chip shows spent/total." },
        { when: "2026-06-06", who: "claude", note: "shipped in 0.0.28. ActionResolveDialog for CHARGE gains a CHARGE DISTANCE section between the pilot picker and OPEN DICE ROLLER — number input ranging 0..½GSPD-already-spent, defaults to current remaining. set-charge-distance handler stores value on state.modal.data.distance without re-render (preserves input focus). RESOLVE clamps to remaining and adds to r.gspdSpent. New r.gspdSpent field in buildBattleRobotState; both round-advance paths (pass-priority and round-next) reset it to 0. Melee dice roll itself ships via existing OPEN DICE ROLLER button (actionRollKind('CHARGE')==='MELEE'). 4 phases verified: gspd 6/half 3/start 0 → spend 2 → 2; try 5 (only 1 left) clamped to 1 → 3; round advance → 0." },
      ],
    },
    {
      id: "dice.strafe_move_plus_ranged",
      summary: "Strafe: ½ GSPD move + per-target ranged. Tokens like Salvo.",
      depends_on: ["dice.salvo_per_target_plus_mental"],
      status: "done",
      acceptance: "Strafe → move + ranged-roll-per-target.",
      history: [
        { when: "2026-06-06", who: "claude", note: "picked up. Strafe = Charge's distance picker (v0.0.28) + Salvo's per-target tokens (v0.0.27). Composes from existing infra: extend k==='CHARGE' branches to k in {CHARGE,STRAFE}, extend k==='SALVO' to k in {SALVO,STRAFE}, add STRAFE to actionShowsPilotPicker. Per rulebook L226, Strafe uses 'up to Ground Speed' (full, not half) — but the action catalog hides that detail. Following v0.0.28 ½GSPD convention for parity; full-GSPD nuance can ship in a future positioning slice." },
        { when: "2026-06-06", who: "claude", note: "shipped in 0.0.29. Three one-liner extensions: actionShowsPilotPicker also returns true for STRAFE, distance-picker section condition + resolve branch both extend k===CHARGE to {CHARGE,STRAFE}, target-picker + token-application both extend k===SALVO to {SALVO,STRAFE}. Toast strings use a.label so 'Strafe — moved N SU' / 'Strafe on N targets' render correctly. Verified: open STRAFE → distance 2 + 2 P2 targets → resolve → gspdSpent=2, both targets receive salvoTokens=1, sysStrain bumps, primary budget used, pilot picker visible, actionRollKind=RANGED." },
      ],
    },
    {
      id: "dice.melee_assault_all_weapons",
      summary: "Melee Assault: one melee roll using every melee weapon. One token per weapon used.",
      depends_on: ["dice.charge_move_plus_melee"],
      status: "done",
      acceptance: "Resolves at robot's melee skill, weapons present in equipped list.",
      history: [
        { when: "2026-06-06", who: "claude", note: "picked up. Gate RESOLVE on robot having ≥1 melee weapon in any non-destroyed component's equipment (keyword 'Melee'). DECISION_LOG: spec says 'token per weapon' but catalog brief says 'token per target' — going with catalog/rulebook L236 ('costs one token per target'). Reuse Salvo target picker by extending the SALVO/STRAFE condition to also include MELEE_ASSAULT." },
        { when: "2026-06-06", who: "claude", note: "shipped in 0.0.30. New robotHasMeleeWeapon(r) helper walks non-destroyed components' equipment[] for any item with 'Melee' in its keywords. Target-picker section condition + RESOLVE token-application branch + Mental-check trigger all extended to include MELEE_ASSAULT (Mental check is gated on isRanged=SALVO|STRAFE only so melee doesn't trip it). MELEE_ASSAULT branch toasts a gate warning when no melee weapon is equipped — doesn't BLOCK resolution (table-resolve fallback still works) but flags the rule violation. Two-toast outcome verified: gate warning then strain confirmation. With sword + 1 P2 target picked → token=1, sysStrain bumps, primary used." },
      ],
    },
    {
      id: "dice.hip_shot_reaction",
      summary: "Hip Shot: reaction, single ranged at attacker. Threshold tweak per rulebook.",
      depends_on: [],
      status: "done",
      acceptance: "Available only as reaction; rolls ranged at attacker.",
      history: [
        { when: "2026-06-06", who: "claude", note: "picked up. Catalog already wires bucket=reaction (budget enforced since v0.0.13) and actionRollKind=RANGED (since v0.0.2). Adding HIP_SHOT to actionShowsPilotPicker so pilot strain routes correctly. The 'rolls ranged at attacker' part is satisfied by opening the existing dice roller — the dice roller doesn't model attacker-specific +/-, so deferred to a future positional slice." },
        { when: "2026-06-06", who: "claude", note: "shipped in 0.0.31. Added HIP_SHOT to actionShowsPilotPicker and actionPilotStrainCost (cost 1 like other ranged actions). Also added STRAFE to actionPilotStrainCost (it was missing from the cost map but already on the picker list since 0.0.29). Verified 5-axis test: showsPicker true, cost 1, rollKind RANGED, 2× consecutive resolves bump sysStrain + pilotStrain + reactionsUsed correctly (1→2 each), 3rd attempt blocked by reaction-budget cap from v0.0.13 ('Both reactions spent this round.')." },
      ],
    },
    {
      id: "dice.quick_strike_reaction",
      summary: "Quick Strike: reaction, single melee. Resolves after attacker.",
      depends_on: [],
      status: "done",
      acceptance: "Same surface as Hip Shot but melee.",
      history: [
        { when: "2026-06-06", who: "claude", note: "picked up. Add QUICK_STRIKE to actionShowsPilotPicker + actionPilotStrainCost (cost 1). actionRollKind('QUICK_STRIKE')==='MELEE' already wired since v0.0.2. Reaction-budget enforcement since v0.0.13." },
        { when: "2026-06-06", who: "claude", note: "shipped in 0.0.32. Two-line catalog extension matching v0.0.31's Hip Shot pattern: QUICK_STRIKE added to actionShowsPilotPicker and actionPilotStrainCost. 6-axis verified: showsPicker true, cost 1, rollKind MELEE, sysStrain bumps to 1, pilotStrain bumps to 1, reactionsUsed 1/2." },
      ],
    },
    {
      id: "dice.parry_threshold_reduce",
      summary: "Parry: reaction. Reduces incoming melee hit threshold by 1.",
      depends_on: [],
      status: "done",
      acceptance: "Parry mid-resolve subtracts 1 hit from the attacker's roll.",
      history: [
        { when: "2026-06-06", who: "claude", note: "picked up. DECISION_LOG: attacker's roll isn't modeled in webapp (rolls happen at the table), so the literal 'subtract 1 hit from attacker's roll' can't be auto-applied here. Ship as: PARRY in pilot picker + cost map + reaction budget; on RESOLVE bump r.pendingParryReductions counter and toast the +1 attacker-threshold rule. Player applies the reduction at the table." },
        { when: "2026-06-06", who: "claude", note: "shipped in 0.0.33. PARRY added to actionShowsPilotPicker + actionPilotStrainCost. Resolve-action branch increments r.pendingParryReductions and toasts 'Parry queued (×N) — +1 to attacker's threshold per parry'. New field initialized in buildBattleRobotState (implicit — undefined treated as 0); both round-advance paths reset it to 0. 3 phases verified: 1st parry→counter 1 + sysStrain 1 + reactions 1/2; 2nd parry→counter 2 + reactions 2/2; round-advance→counter 0." },
      ],
    },
    {
      id: "dice.boost_dodge_fuel",
      summary: "Boost Dodge: reaction, dodge + reduce inertia. Costs fuel.",
      depends_on: [],
      status: "done",
      acceptance: "Spend fuel, +1 die on dodge.",
      history: [
        { when: "2026-06-06", who: "claude", note: "picked up. Per rulebook L248: Boost Dodge = Physical check + Boost equal to hits + costs fuel. Add BOOST_DODGE to actionShowsPilotPicker + actionPilotStrainCost (cost 1, matching Hip Shot/Quick Strike pattern). Resolve-action branch: refuse if fuelCurrent < 1, otherwise decrement fuel by 1 and toast +1 die on dodge per rulebook." },
        { when: "2026-06-06", who: "claude", note: "shipped in 0.0.34. BOOST_DODGE added to actionShowsPilotPicker + actionPilotStrainCost. Fuel gate at top of resolve-action (BEFORE the action cascade) refuses with 'Boost Dodge needs ≥ 1 fuel' when fuelCurrent < 1, leaving strain/budget/pilot untouched. When fuel is sufficient, the reaction branch deducts 1 fuel and toasts '−1 Fuel, +1 die on the Physical check'. Two-arm verified: fuel 3 → fuel 2 + sysStrain 1 + pilotStrain 1 + reactions 1 + both toasts; fuel 0 → refused, all counters at 0. Closes stage 6 action dice flows (8 slices, 0.0.27 → 0.0.34)." },
      ],
    },
  ],

  // ── Stage 7: modules + capacitor + equipment ──────────────────────
  stage_7_modules_caps_equipment: [
    {
      id: "modules.toggle_costs_and_reqs",
      summary: "Module toggle (on/off) validates: fuel ≥ cost, power available. Persists active state.",
      depends_on: [],
      status: "done",
      acceptance: "Toggle a fuel-cost-2 module with fuel=1 → toast: 'not enough fuel'.",
      history: [
        { when: "2026-06-06", who: "claude", note: "picked up. Current toggle-mod handler flips toggledOn without any cost/req validation. Add: fuel cost = MODULES_BY_ID[mid].fuelToActivate || 0; turning ON refuses if r.fuelCurrent < cost; turning OFF is always allowed (frees fuel/power back). Power validation: turning ON refuses if net power deficit exceeds available — compute power budget = sum of module.power across non-destroyed components, refuse if deficit > 0 after activation." },
        { when: "2026-06-06", who: "claude", note: "shipped in 0.0.35. toggle-mod handler now gates ON-flips on (a) fuel ≥ MODULES_BY_ID[id].fuelToActivate (defaults to 0), and (b) net power budget across all currently-active modules in non-destroyed components plus the candidate's power contribution stays ≥ 0. Negative-net refusal toasts the projected deficit. Successful ON deducts fuel. OFF flips bypass all checks. 4 cases verified at synthetic fuel_burner (fuel cost 2, power -3): fuel=1 refused; fuel=5 no-reactor refused (-5 deficit); fuel=5 with reactor activated + fuel 5→3; OFF flip with fuel=0 allowed silently." },
      ],
    },
    {
      id: "modules.capacitor_pool",
      summary: "Capacitor (CAP) pool: +1 per round, spendable by Shield Recovery (+10 SHLD), Strain Clear (-1 STR), etc.",
      depends_on: ["budget.end_of_round_refresh"],
      status: "done",
      acceptance: "Round advances → CAP +=1 (cap=max-of-capacitor-modules). Shield Recovery action spends 1.",
      history: [
        { when: "2026-06-06", who: "claude", note: "picked up. Verification slice — round-advance +1 (clamped to capacitorsMax) shipped 0.0.15; SHIELD_RECOVERY −1 cap +10 shields shipped 0.0.6; STRAIN_CLEAR −1 cap −1 strain shipped 0.0.6. All paths exist; running end-to-end Playwright to confirm + close." },
        { when: "2026-06-06", who: "claude", note: "shipped in 0.0.36 (no code changes — pure verification). End-to-end Playwright with cap 2/4, shields 10/30, strain 2: SHIELD_RECOVERY → cap 1, shields 20 (+10 capped at max); STRAIN_CLEAR → cap 0, strain 1; 2nd SHIELD_RECOVERY refused with 'Can't recover shields (no cap or already full)' toast; PASS round advance → cap 0→1 (rulebook +1); 3 more PASS rounds → round 5, cap clamped at max 4 not 5. All paths working as specified." },
      ],
    },
    {
      id: "equipment.hp_track",
      summary: "Equipment.hpCurrent / hpMax. Take damage → reduce. At 0 → broken (visually struck, unequipped).",
      depends_on: ["damage.recompute_derived_stats"],
      status: "done",
      acceptance: "Damage equipment in component sheet → HP reduces; at 0, broken chip.",
      history: [
        { when: "2026-06-06", who: "claude", note: "picked up. DECISION_LOG: webapp uses armorCurrent/armorMax naming on equipment (legacy from v0.0.1, parallel to component hpCurrent/hpMax). Keep that. DAMAGE −1 / REPAIR / red-amber-muted ARM chip + DAMAGED disabled button ALL already wired. Adding: explicit BROKEN red chip on row, line-through + dim on broken equipment name, and filter broken equipment out of robotHasMeleeWeapon so Melee Assault gate respects breakage." },
        { when: "2026-06-06", who: "claude", note: "shipped in 0.0.37. comp-sheet equipment rows: card now dims to opacity 0.6 + name gets text-decoration:line-through + adds an explicit red BROKEN chip when armorCurrent <= 0. robotHasMeleeWeapon now skips equipment whose armorMax > 0 && armorCurrent <= 0 — Melee Assault's gate from v0.0.30 now recognizes a broken sword as unequipped. 4 phases verified: working sword → hasMelee true; damage to 0 → hasMelee false + UI shows BROKEN + DAMAGED button; repair → hasMelee true." },
      ],
    },
    {
      id: "equipment.mount_swap",
      summary: "Mount-Point keyword equipment can be swapped at deploy. After battle starts, no swap unless Grab/Drop.",
      depends_on: [],
      status: "done",
      acceptance: "Editor allows mount swap; battle locks it.",
      history: [
        { when: "2026-06-06", who: "claude", note: "picked up. Verification slice. The two-shape model (build robot in state.robots, battle robot snapshot in state.activeBattle.p*Robots) already implements the gate: garage's wizard + hub edit the build shape freely; battle's comp-sheet only exposes DAMAGE/REPAIR — no add/remove/swap controls. Grab/Drop mid-battle equipment handoff between robots is NOT modeled (that's a positional-keyword interaction for a future slice). DECISION_LOG: keep the all-equipment-locked behavior; the Mount-Point-specific exception via Grab/Drop is more permissive than current and ships later." },
        { when: "2026-06-06", who: "claude", note: "shipped in 0.0.38 (no code changes — verification only). Playwright: edit state.robots[0] to add an Axe → build shape now [Sword, Axe], but state.activeBattle.p1Robots[0] still [Sword] because deploy snapshots equipment at deploy time. Battle comp-sheet check confirmed it has DAMAGE controls but NO add/remove/swap UI affordance (regex match against 'add equipment|swap|mount swap' returned false). Closes stage 7 modules + capacitor + equipment." },
      ],
    },
  ],

  // ── Stage 8: positioning + status conditions ──────────────────────
  stage_8_positioning_status: [
    {
      id: "positioning.gspd_tracking",
      summary: "Track GSPD spent per round. Move action deducts. Boost increases. Decelerate reduces inertia.",
      depends_on: ["budget.per_robot_action_pool"],
      status: "done",
      acceptance: "GSPD chip shows X/Y remaining; spending Move dialogs prompt amount; deducts.",
      history: [
        { when: "2026-06-06", who: "claude", note: "picked up. r.gspdSpent already exists since v0.0.28 + Charge/Strafe deduct + round reset. This slice: (1) vitals GSPD chip now reads X/Y remaining (current GSPD - gspdSpent / GSPD), (2) extend distance picker to MOVE — full GSPD (not ½) per rulebook L222. Boost/Decelerate ship in subsequent positioning slices." },
        { when: "2026-06-06", who: "claude", note: "shipped in 0.0.39. Per-robot vitals GSPD cell now reads `${remaining}/${total}` instead of just total; cell flips to .warn class when fully spent. Distance picker section + resolve-action GSPD branch extended to handle MOVE: MOVE uses full Ground Speed per rulebook L222, CHARGE/STRAFE keep their ½GSPD cap. Section header now interpolates a.label so it reads MOVE DISTANCE / CHARGE DISTANCE / STRAFE DISTANCE. 4 phases verified at GSPD 6: chip 6/6 → MOVE 4 → chip 2/6 → MOVE 5 (clamped to 2) → chip 0/6 → CHARGE attempt → still 6 (no further spend allowed)." },
      ],
    },
    {
