// ────────────────────────────────────────────────────────────────────
// URFS Web — full-port spec
//
// Source of truth for the webapp's "no gaps" build-out. Each iteration
// of /loop /urfs-webapp-iterate picks the next pending item, ships it,
// bumps the version, updates the README changelog, commits.
//
// Status values: pending | in_progress | done | blocked
// Version scheme: 0.0.N pre-release. Each item shipped bumps N.
//
// Rules: webapp is single-file (index.html). All code goes there.
// IndexedDB shape MUST stay compatible with the Android RobotEntity /
// ComponentEntity / ModuleInstance / BattleState so a future Android
// importer can read the JSON export round-trip.
// ────────────────────────────────────────────────────────────────────
{
  meta: {
    repo: "/home/tom/software_projects/urfs/webapp",
    file: "index.html",
    branch: "master",
    current_version: "0.0.12",
    rulebook: "/home/tom/software_projects/urfs/android/app/src/main/assets/rulebook.md",
    revision_notes: "/home/tom/software_projects/urfs/docs/rulebook/RULEBOOK_REVISION_NOTES.md",
    android_reference: "/home/tom/software_projects/urfs/android/app/src/main",
    constraint_single_file: true,
    note: "Android side already implements everything here. Port the algorithm, don't redesign.",
  },

  // ── Stage 1: bind pilots to cockpit slots at deploy ────────────────
  // Unblocks the dice-roller pilot-talent chips (Sharpshooter, Deadeye,
  // Brawler) AND the action-resolve strain routing.
  stage_1_cockpit_binding: [
    {
      id: "cockpit.collect_slots_from_robot",
      summary: "Derive cockpit slot count per robot from its components (any module whose catalog entry marks it as a cockpit-bearing module — single-pilot, multi-pilot, open-air, etc). Adapter only — no UI.",
      depends_on: [],
      status: "done",
      acceptance: "robotCockpitSlots(r) returns array of {componentId, componentName, moduleIndex, moduleId, slotIndex, slotName} for every cockpit slot the robot exposes. Multi-pilot modules contribute multiple slots.",
      history: [
        { when: "2026-06-05", who: "claude", note: "picked up — implementing adapter only, no UI surface." },
        { when: "2026-06-05", who: "claude", note: "shipped in 0.0.3. robotCockpitSlots() at index.html:726-756. Returns {componentId, componentName, moduleIndex, moduleId, moduleName, slotIndex, slotName, isAi} per slot. componentId fallback handles build (tempId) vs battle/force (componentId). Multi-pilot supported via inner capacity loop. 6 Playwright eval cases verified: empty, single, dual (Std+AI), unknown-module skip, non-cockpit-module skip, input-unmutated." },
      ],
    },
    {
      id: "cockpit.deploy_step_assign_pilots",
      summary: "Force deploy flow: after picking robots, show a pilot-assignment step. One picker per cockpit slot. Validates: no double-booking pilots across slots.",
      depends_on: ["cockpit.collect_slots_from_robot"],
      status: "done",
      acceptance: "Deploying a force with N cockpit-bearing mechs prompts N×slots pilot pickers; cancel returns to robot picker; confirm stores assignments on battle.cockpitPilots[].",
      history: [
        { when: "2026-06-05", who: "claude", note: "picked up — inserting pilot-assignment step between deploy click and battle launch." },
        { when: "2026-06-05", who: "claude", note: "shipped in 0.0.4. forceCockpitSlots(force) adapter (pure) + renderPilotAssign modal with per-slot <select> + double-booking filter + AI-Core auto-skip + 0-cockpit fast-path + empty-pilots empty-state banner with GO TO PILOTS shortcut. Wired through document-level change delegation (matches data-act convention). deployForceWithAssignments builds battle.cockpitPilots[] = [{componentId, moduleIndex, slotIndex, slotName, pilotId, isAi, sysStrain:0, pilotStrain:0}] per slot. 7+3 Playwright cases verified." },
      ],
    },
    {
      id: "cockpit.persist_in_battle_state",
      summary: "battle.cockpitPilots = [{robotId, componentId, slotIndex, pilotId, sysStrain:0, pilotStrain:0}]. Survives IndexedDB round-trip.",
      depends_on: ["cockpit.deploy_step_assign_pilots"],
      status: "done",
      acceptance: "Export JSON includes cockpitPilots[]; import restores them; per-robot screen reads them.",
      history: [
        { when: "2026-06-05", who: "claude", note: "picked up. DECISION_LOG: previous slice stored cockpitPilots nested on each BattleRobotState (per-robot) rather than flat at battle level. Keeping that shape — destruction cascades + display affordances are O(1) when nested. Spec text 'battle.cockpitPilots' read as 'somewhere on the battle object' rather than literal top-level key." },
        { when: "2026-06-05", who: "claude", note: "shipped in 0.0.5. Round-trip verified — generic export/import pipeline carries cockpitPilots through the battles store without code changes. renderCockpitPilots(r) added between vitals and action sheet on per-robot screen: cyan-accented PILOTS bucket with one row per cockpit (slot name + pilot name chip + rank · STR sysStrain/pilotStrain; AI Core slots show 'A.I. Core' chip; stale-id pilots show 'unassigned'). New CSS: .bucket.pilots .header (cyan), .bucket.pilots.open border-color, .header.static / .list-card.static cursor:default to remove false-affordance from non-clickable rows. 3 Playwright cases verified including round-trip + visual." },
      ],
    },
    {
      id: "cockpit.pilot_picker_in_action_resolve",
      summary: "When an action needs strain routing (most Primary actions), ActionResolveDialog shows a pilot picker listing every cockpit pilot on this robot.",
      depends_on: ["cockpit.persist_in_battle_state"],
      status: "done",
      acceptance: "Salvo + Charge + Melee Assault + Heat Vent show pilot picker; RESOLVE routes the +1 P STRAIN to that pilot's pilotStrain.",
      history: [
        { when: "2026-06-05", who: "claude", note: "picked up. Plan: add pilot picker to ActionResolveDialog when action.pilotStrainCost > 0; on RESOLVE, mutate the chosen cockpitPilots entry's pilotStrain." },
        { when: "2026-06-05", who: "claude", note: "shipped in 0.0.6. New helpers actionShowsPilotPicker(k) {SALVO|CHARGE|MELEE_ASSAULT|HEAT_VENT} and actionPilotStrainCost(k) (1 for first three, 0 for HEAT_VENT — Mental check is Free). Picker rewritten to filter humanCockpits (skip AI), composite-key 'componentId:moduleIndex:slotIndex' identity (not array index), default-pick first human row with cyan-border highlight, MANUAL escape-hatch preserved. RESOLVE handler replaces stale .tokens reference with cockpitPilots.find().pilotStrain += cost; sysStrain unchanged (still bumps for primary/reaction bucket). PASS handler bug fixed: now clears pilotStrain on every cockpit pilot (per v0.0.1 README + rulebook, PASS clears Pilot Strain). DECISION_LOG: auto-default pick on first render is intentional UX (single-cockpit case saves a tap; multi-cockpit user sees cyan border on default + can tap to override). modal-close resets _pickedPilot to null to prevent cross-action leak. 7+1 Playwright cases verified including PASS→strain=0 round-trip." },
      ],
    },
    {
      id: "cockpit.dice_chips_wake_up",
      summary: "Dice roller chip catalog: enumerate the cockpit pilots on this robot and surface their talent chips (Sharpshooter for ranged, Deadeye for ranged, Brawler for melee, etc.).",
      depends_on: ["cockpit.persist_in_battle_state"],
      status: "done",
      acceptance: "Open dice roller for SALVO with a Sharpshooter pilot bound → Sharpshooter chip appears, togglable, +1 die when active.",
      history: [
        { when: "2026-06-05", who: "claude", note: "picked up. Plan: walk cockpitPilots → lookup pilot.talents → emit matching chips for the rollKind." },
        { when: "2026-06-05", who: "claude", note: "shipped in 0.0.7. Fixed dormant bug in rollerComputeChips: was reading cp.talents off the cockpitPilots entry shape (which never had a talents field) — now looks up talents via state.pilots.find(p => p.id === cp.pilotId)?.talents, filtered to non-AI cockpits with a pilotId. Sharpshooter/Deadeye/Brawler chip enumeration was already correct, just sourced empty. Acceptance verified: deploy Eagle (Sharpshooter+Brawler) → SALVO roller surfaces +3 SHARPSHOOTER chip; CHARGE surfaces +1 BRAWLER; MENTAL surfaces neither. Toggle+pool: base 4 + Sharpshooter 3 = 7 d6 displayed." },
      ],
    },
  ],

  // ── Stage 2: two-sided combat (P2 force + priority handoff) ────────
  stage_2_two_sides: [
    {
      id: "twosides.battle_state_two_forces",
      summary: "battle.forces = [{side:'P1', forceId, robotIds[]}, {side:'P2', forceId, robotIds[]}]. Migration: existing single-force battles become side='P1', P2 empty.",
      depends_on: [],
      status: "done",
      acceptance: "Old export JSON imports fine; new battles store both sides; per-robot screens still resolve correctly.",
      history: [
        { when: "2026-06-05", who: "claude", note: "picked up. DECISION_LOG: existing webapp model already has battle.p1Robots[] + battle.p2Robots[] (p2 always [] for now) and battle.p1ForceName + battle.p2ForceName. Keeping this shape — it's structurally equivalent to the spec's battle.forces[] proposal. This iteration: add findBattleRobot(b, rid) lookup helper that searches both sides, ensure legacy battles get p2Robots:[] default on import, add p1ForceId for traceability." },
        { when: "2026-06-05", who: "claude", note: "shipped in 0.0.8. findBattleRobot(b, rid) helper added; 31 prior p1Robots.find() callsites refactored to use it (searches both p1 + p2). p1ForceId stored on deploy (next slice will read it for OPPONENT styling). renderBattleOverview now renders OPPONENT FORCE section when p2Robots.length > 0; solo battles unchanged. Legacy migration applied at BOTH ingress paths: init (load from IndexedDB) AND import-json — old battles missing p2Robots default to []. Playwright regression check: p1 lookup, p2 lookup, SALVO → pilotStrain++, p1ForceId set. Forward-prep: p1ForceId/p2ForceId are write-only until next slice; OPPONENT section uses neutral chrome (will get --red palette in twosides.battle_overview_both_sides)." },
      ],
    },
    {
      id: "twosides.deploy_picks_two_forces",
      summary: "Deploy flow asks: P1 force + P2 force (optional). If P2 omitted, default-empty (skirmish/solo).",
      depends_on: ["twosides.battle_state_two_forces"],
      status: "done",
      acceptance: "Deploy 2 forces → battle has 6 robot cards in two sections (YOUR / OPPONENT).",
      history: [
        { when: "2026-06-05", who: "claude", note: "picked up. DECISION_LOG: post-deploy '+ ADD OPPONENT FORCE' button on battle overview rather than re-plumbing pre-deploy flow. Less disruption to v0.0.4 pilot-assign code; mirrors table-play where opponent may show up later. Tap opens force picker (excluding current p1ForceId) → existing pilot-assign modal reused with side='P2' context → robots pushed to p2Robots, p2ForceId set." },
        { when: "2026-06-05", who: "claude", note: "shipped in 0.0.9. New '+ ADD OPPONENT FORCE' button on battle overview (visible when p2Robots.length === 0). renderOpponentForcePicker filters out (a) the deployed P1 force AND (b) any force that contains a robot.id also in p1Robots — second filter prevents findBattleRobot collisions (first-match-wins would make a P2 instance unreachable). Reused renderPilotAssign with side='P2' param; confirm-pilot-assign branches: P1 → deployForceWithAssignments creates new battle (unchanged), P2 → builds battle-robot states for the existing battle and pushes to p2Robots. p1ForceName has 'your force' fallback for legacy battles. 7+1 Playwright cases verified: end-to-end 1+2 deploy, collision filter excludes Force C (shares robot with deployed P1), legacy-battle fallback label." },
      ],
    },
    {
      id: "twosides.battle_overview_both_sides",
      status: "done",
      summary: "Battle overview renders YOUR FORCE and OPPONENT FORCE sections, each with their robot cards. Tap-to-detail works on either side.",
      history: [
        { when: "2026-06-05", who: "claude", note: "shipped in 0.0.10. CSS: new .card.friendly (3px cyan left border) and .card.opposing (3px red left border) modifiers; reused existing --cyan / --red tokens. renderBattleOverview headers use .label-cyan / .label-red on YOUR / OPPONENT label-small. robotOverviewCard now applies sideClass = r.side === 'P2' ? 'opposing' : 'friendly'. Tap-to-detail verified for P2 (clicked P2Bot card → state.activeRobotId === 4002 via findBattleRobot). Visual screenshot captured." },
      ],
      depends_on: ["twosides.deploy_picks_two_forces"],
      acceptance: "Visual: two header sections with color-distinct chrome (cyan vs red).",
    },
    {
      id: "twosides.priority_handoff",
      summary: "Round tracker shows current priority holder (P1 or P2). PASS PRIORITY button hands off to the other side. After both have passed, end of round.",
      depends_on: ["twosides.battle_overview_both_sides"],
      status: "done",
      history: [
        { when: "2026-06-05", who: "claude", note: "picked up. Plan: add b.passedThisRound={P1:false,P2:false}; PASS marks current priority side passed + flips; on double-pass advance round + reset flags + reset priority to P1; existing handler is buggy (only resets P1, uses stale .tokens field)." },
        { when: "2026-06-05", who: "claude", note: "shipped in 0.0.11. pass-priority handler rewritten as a proper state machine. Reads current b.priority, clears pilot strain on THAT side only (was the bug — old code only ever cleared P1), marks b.passedThisRound[side]=true, flips priority to other side. When both sides have b.passedThisRound true, advances round: round++, passedThisRound reset, priority reset to P1. Solo (p2Robots empty) takes a fast path — single PASS advances the round directly. UI: per-side chip shows '✓ PASSED' (muted) when that side has passed, 'PRIORITY' (amber) when that side holds priority. 3-state trace verified: Round 1 P1→P2 priority with P1 strain cleared; P2 pass → Round 2 begins with both strains cleared; solo path → single PASS → Round 2." },
      ],
      acceptance: "Round 1 → P1 has priority → P1 PASS → P2 has priority → P2 PASS → Round 2 begins.",
    },
  ],

  // ── Stage 3: action budget + round state machine ──────────────────
  stage_3_action_budget: [
    {
      id: "budget.per_robot_action_pool",
      summary: "Per-robot per-round: 1 Primary, 2 Reactions, ∞ Incidentals. State held on battle.robotState[robotId] = {primaryUsed, reactionsUsed, incidentalsUsed}.",
      depends_on: ["twosides.priority_handoff"],
      status: "done",
      acceptance: "Spending an action increments the right counter; state persists on save/restore.",
      history: [
        { when: "2026-06-05", who: "claude", note: "picked up. DECISION_LOG: storing actionBudget nested on each BattleRobotState (consistent with cockpitPilots[] pattern) instead of a sibling battle.robotState{robotId} map. Easier round-trip, easier per-robot lookup, no map serialization concerns. Spec's literal map form is functionally equivalent." },
        { when: "2026-06-05", who: "claude", note: "shipped in 0.0.12. buildBattleRobotState now initializes actionBudget:{primaryUsed:0, reactionsUsed:0, incidentalsUsed:0}. resolve-action handler bumps the matching counter (primary/reaction/incidental from a.bucket) on each resolve (excluding PASS, which is its own thing). pass-priority's round-advance branch resets all robots' actionBudget back to zeros across both sides. 5-phase Playwright trace verified: deploy 0/0/0 → Salvo 1/0/0 → Dodge 1/1/0 → Pivot 1/1/1 → PASS round-up 0/0/0 + round=2. UI affordances (disable spent buttons, ACTIONS THIS ROUND chip) come in the next two slices." },
      ],
    },
    {
      id: "budget.disable_spent_actions",
      summary: "ActionResolveDialog: if a Primary was already used this round, all Primary actions render dimmed + disabled. Same for 2 Reactions used.",
      depends_on: ["budget.per_robot_action_pool"],
      status: "pending",
      acceptance: "After Salvo resolves, every Primary action in the list is unselectable until end of round.",
    },
    {
      id: "budget.actions_this_round_panel",
      summary: "Per-robot screen: ACTIONS THIS ROUND chip row: P:1/1, R:0/2, I:3. Color when at-cap.",
      depends_on: ["budget.per_robot_action_pool"],
      status: "pending",
      acceptance: "Visual chips that mirror rulebook caps.",
    },
    {
      id: "budget.end_of_round_refresh",
      summary: "End-of-round button: refresh all robots' budgets, increment round counter, tick strain recovery if rules allow, fire +1 capacitor.",
      depends_on: ["budget.actions_this_round_panel"],
      status: "pending",
      acceptance: "Round 2 begins → every robot back to P:0/1, R:0/2, I:0; +1 capacitor on robots that don't override.",
    },
  ],

  // ── Stage 4: damage pipeline (buffer → frame save → cascade) ──────
  // This is the marathon. Port from android SchematicBattleViewModel +
  // FrameSaveResolver + DestructionCascade.
  stage_4_damage_pipeline: [
    {
      id: "damage.apply_damage_dialog",
      summary: "New APPLY DAMAGE button on per-robot screen. Target component picker + damage-amount input + type (kinetic/energy/etc).",
      depends_on: [],
      status: "pending",
      acceptance: "Opens a dialog; on submit, calls applyDamage(robotId, componentId, amount, type).",
    },
    {
      id: "damage.buffer_absorbs_first",
      summary: "applyDamage: subtract from component.armor first (down to 0). Overflow = breach. No frame save if armor absorbed everything.",
      depends_on: ["damage.apply_damage_dialog"],
      status: "pending",
      acceptance: "Component with armor 5, take 3 damage → armor=2, no save prompt. Take 7 damage → armor=0, save prompted on 2 breach.",
    },
    {
      id: "damage.frame_save_dialog",
      summary: "On breach: dialog showing FD d6 vs 7-FM+ threshold. Roll button. Outcome is binary: save success → component intact; save fail → component destroyed (no HP loss — components have no HP stat per rulebook).",
      depends_on: ["damage.buffer_absorbs_first"],
      status: "pending",
      acceptance: "FD=2, FM=3 → roll 2 d6 vs 4+. Show dice, count hits. Hits ≥ 1 = save succeeds, breach absorbed. Hits = 0 = component is destroyed (binary).",
    },
    {
      id: "damage.destruction_cascade",
      summary: "Failed save → component.isDestroyed = true → cascade per Android: stowed children destroyed, fuel-tank components spill (collateral), equipment-grabber components drop equipment.",
      depends_on: ["damage.frame_save_dialog"],
      status: "pending",
      acceptance: "Failed save destroys component; destroy a host with 3 stowed components → all 3 marked destroyed; destroy a fuel tank → adjacent components take spill damage per rulebook.",
    },
    {
      id: "damage.recompute_derived_stats",
      summary: "After any destruction: recomputeShieldsMax, recomputeCapacitorPool, enforceAuxReactorDependency, refreshPowerAndCheck, recomputeStrainThreshold. Port from Android.",
      depends_on: ["damage.destruction_cascade"],
      status: "pending",
      acceptance: "Destroying the shields module zeros the SHLD max; destroying aux reactor disables dependent modules.",
    },
    {
      id: "damage.undo_restore_in_combat",
      summary: "Port restoreComponent from Android alpha.356: UNDO·RESTORE button on destroyed-component overlay clears flag, restores HP, re-runs recompute helpers.",
      depends_on: ["damage.recompute_derived_stats"],
      status: "pending",
      acceptance: "Misclick destroy → tap UNDO·RESTORE → component back to full HP, derived stats snap back.",
    },
  ],

